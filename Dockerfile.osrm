# Use the builder image as a data source
# Note: osrm-data-builder must be available in the local registry
FROM osrm-data-builder as data

FROM ghcr.io/project-osrm/osrm-backend

# Argument to select the profile for runtime
ARG PROFILE=car
ENV PROFILE=${PROFILE}

# Copy the entire processed data structure
COPY --from=data /data /data

# Set working directory to the specific profile
WORKDIR /data/${PROFILE}
